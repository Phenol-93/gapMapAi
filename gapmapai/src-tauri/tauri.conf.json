{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GapmapAI",
  "version": "0.1.0",
  "identifier": "com.phenol93.gapmapai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:gapmap-ai.db"]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GapmapAI",
        "width": 1280,
        "height": 820,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
